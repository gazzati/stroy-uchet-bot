{
  "name": "stroy-uchet-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "clean": "rm -rf build",
    "build": "yarn clean && tsc -p tsconfig.build.json",
    "start": "node build/index.js",
    "dev": "tsx watch src/index.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "test": "vitest run",
    "type": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "grammy": "^1.34.0",
    "kysely": "^0.29.2",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.11",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
